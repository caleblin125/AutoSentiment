#!/usr/bin/env bash
# agent-run — launch any agent with credit-exhaustion detection,
# graceful cleanup, and relay message listening.
#
# Usage: agent-run <agent-name> <agent-cmd...>
#   agent-run pi pi --model claude-sonnet-4-7
#   agent-run claude claude --model claude-opus-4-7
#   agent-run codex codex --model gpt-5.5
#
# Environment:
#   AGENT_PROJECT_DIR  — project root (default: current dir)
#   AGENT_RELAY_FIFO   — relay pipe path (default: /tmp/agent-relay)
#
# On credit exhaustion (detected via exit code, stderr patterns, or
# API error messages in stdout), the agent:
#   1. Marks all its claimed tasks back to [FREE] in AGENT_TASKS.md
#   2. Removes itself from AGENT_ACTIVE.md
#   3. Logs the exit to AGENT_LOG.md
#   4. Exits cleanly

set -euo pipefail
shopt -s lastpipe

AGENT_NAME="${1:?Usage: agent-run <name> <cmd...>}"
shift
AGENT_CMD=("$@")

PROJECT_DIR="${AGENT_PROJECT_DIR:-$(pwd)}"
RELAY_FIFO="${AGENT_RELAY_FIFO:-/tmp/agent-relay}"
RELAY_PID=""

# ── Ensure coordination files exist ──────────────────────────────────────
cd "$PROJECT_DIR"
touch AGENT_TASKS.md AGENT_ACTIVE.md AGENT_LOG.md AGENT_MAILBOX.md

# ── Create relay FIFO if not exists ──────────────────────────────────────
if [[ ! -p "$RELAY_FIFO" ]]; then
    mkfifo "$RELAY_FIFO" 2>/dev/null || true
fi

# ── Cleanup function — called on ANY exit ────────────────────────────────
cleanup() {
    local exit_code=$?
    local reason="${1:-exited}"

    # Kill relay listener if running
    [[ -n "$RELAY_PID" ]] && kill "$RELAY_PID" 2>/dev/null || true

    # Mark claimed tasks back to FREE
    if [[ -f AGENT_TASKS.md ]]; then
        sed -i "s/\[$AGENT_NAME\]/[FREE]/g" AGENT_TASKS.md
    fi

    # Remove from active sessions
    if [[ -f AGENT_ACTIVE.md ]]; then
        sed -i "/| $AGENT_NAME |/d" AGENT_ACTIVE.md
    fi

    # Log the exit
    local ts
    ts="$(date -u +"%Y-%m-%d %H:%M UTC")"
    {
        echo ""
        echo "## $ts | $AGENT_NAME"
        echo "- Exited: $reason (code $exit_code)"
        echo "- Cleaned claims, removed from active sessions"
    } >> AGENT_LOG.md

    # Remove relay FIFO if no other agents are listening
    local active_count
    active_count=$(grep -c "| [a-z].*|" AGENT_ACTIVE.md 2>/dev/null || echo 0)
    if [[ "$active_count" -eq 0 ]]; then
        rm -f "$RELAY_FIFO"
    fi

    exit "$exit_code"
}
trap 'cleanup "interrupted"' SIGINT SIGTERM
trap 'cleanup "error"' ERR

# ── Register this agent ──────────────────────────────────────────────────
AGENT_LABEL="${AGENT_NAME}-$(date +%H%M%S)"
ts="$(date -u +"%Y-%m-%d %H:%M UTC")"
sed -i "/^## $ts/d" AGENT_LOG.md 2>/dev/null || true
{
    echo ""
    echo "## $ts | $AGENT_NAME"
    echo "- Started session $AGENT_LABEL"
    echo "- Command: ${AGENT_CMD[*]}"
} >> AGENT_LOG.md

# ── Relay listener: reads from FIFO, appends to agent mailbox ────────────
start_relay_listener() {
    while true; do
        if read -r line < "$RELAY_FIFO" 2>/dev/null; then
            local rts
            rts="$(date -u +"%Y-%m-%d %H:%M UTC")"
            # Inject into this agent's stdin by writing to a temp file
            # that the agent can pick up. For pi/claude/codex, we
            # interrupt and inject the message.
            {
                echo ""
                echo "## relay → $AGENT_NAME ($rts)"
                echo "$line"
            } >> AGENT_MAILBOX.md

            # For ptty-based agents, we use tmux send-keys if available
            local pane
            pane="${AGENT_TMUX_PANE:-}"
            if [[ -n "$pane" ]] && tmux has-session -t "$pane" 2>/dev/null; then
                tmux send-keys -t "$pane" C-c  # interrupt current work
                sleep 0.5
                tmux send-keys -t "$pane" "RELAY: $line" Enter
            fi
        fi
    done
}

# Start relay listener in background
start_relay_listener &
RELAY_PID=$!

# ── Register in active sessions ──────────────────────────────────────────
ts="$(date -u +"%Y-%m-%d %H:%M UTC")"
# Append a row to the active table
cat >> AGENT_ACTIVE.md <<EOF
| $AGENT_NAME | $AGENT_LABEL | — | — | active | $ts |
EOF

# ── Launch the agent, capture output for credit detection ────────────────
STDERR_FILE="$(mktemp)"
STDOUT_FILE="$(mktemp)"

set +e
"${AGENT_CMD[@]}" >"$STDOUT_FILE" 2>"$STDERR_FILE"
AGENT_EXIT=$?
set -e

# ── Credit exhaustion detection ──────────────────────────────────────────
CREDIT_EXHAUSTED=false
STDERR_TEXT="$(cat "$STDERR_FILE")"
STDOUT_TEXT="$(cat "$STDOUT_FILE")"

# Patterns that indicate credit/rate-limit exhaustion
CREDIT_PATTERNS=(
    "rate limit reached"
    "credits.*exceeded"
    "quota exceeded"
    "billing.*limit"
    "insufficient.*credit"
    "no.*credits.*remaining"
    "payment required"
    "402"
    "429"
    "plan.*upgrade"
    "usage limit"
    "too many requests"
)

for pattern in "${CREDIT_PATTERNS[@]}"; do
    if echo "$STDERR_TEXT$STDOUT_TEXT" | grep -qi "$pattern"; then
        CREDIT_EXHAUSTED=true
        break
    fi
done

# Also check exit codes that suggest API/credit issues
if [[ "$AGENT_EXIT" -eq 1 ]] && echo "$STDERR_TEXT" | grep -qi "api\|auth\|key\|token\|credit\|billing\|quota"; then
    CREDIT_EXHAUSTED=true
fi

# ── Clean exit ───────────────────────────────────────────────────────────
rm -f "$STDERR_FILE" "$STDOUT_FILE"

if $CREDIT_EXHAUSTED; then
    cleanup "credit exhausted"
else
    cleanup "completed (exit $AGENT_EXIT)"
fi
