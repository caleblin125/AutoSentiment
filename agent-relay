#!/usr/bin/env bash
# agent-relay — broadcast a message to all active agents.
#
# Usage: agent-relay "Fix the sentiment label bug in builder.py"
#        agent-relay "All agents: switch to priority 2 tasks"
#
# Writes the message to the relay FIFO. All agents with an active
# relay listener will receive it via their AGENT_MAILBOX.md and,
# if running in tmux, via tmux send-keys.
#
# Also appends to AGENT_MAILBOX.md directly for agents that may
# not have a relay listener running.

set -euo pipefail

MESSAGE="${1:?Usage: agent-relay <message>}"
PROJECT_DIR="${AGENT_PROJECT_DIR:-$(pwd)}"
RELAY_FIFO="${AGENT_RELAY_FIFO:-/tmp/agent-relay}"

cd "$PROJECT_DIR"

# ── Write to relay FIFO (non-blocking, in case no listener) ──────────
if [[ -p "$RELAY_FIFO" ]]; then
    echo "$MESSAGE" > "$RELAY_FIFO" 2>/dev/null || true
fi

# ── Also write directly to mailbox ────────────────────────────────────
TS="$(date -u +"%Y-%m-%d %H:%M UTC")"
{
    echo ""
    echo "## user → all ($TS)"
    echo "$MESSAGE"
} >> AGENT_MAILBOX.md

# ── Broadcast to all tmux sessions with agents ────────────────────────
for pane in $(tmux list-panes -a -F '#{session_name}:#{pane_index}' 2>/dev/null); do
    session="${pane%%:*}"
    # Skip non-agent sessions
    case "$session" in
        agent-*|autosentiment-*)
            tmux send-keys -t "$pane" C-c 2>/dev/null || true
            sleep 0.3
            tmux send-keys -t "$pane" "📢 RELAY: $MESSAGE" Enter 2>/dev/null || true
            ;;
    esac
done

echo "Relayed to all active agents: $MESSAGE"
