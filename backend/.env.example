# Copy to .env — never commit real secrets.

# Hackathon: align NEMCLAW_MODEL / LIGHTWEIGHT_MODEL with NemoClaw onboarding + shortesthack.com Nemoclaw tab.
# See ../docs/HACKATHON_ENV.md and https://www.shortesthack.com/?tab=nemoclaw

# SQLite URL for dev (default if unset: sqlite+aiosqlite:///./data/app.db)
# DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# NemoClaw / planning route — high-capability model id or alias from your environment
# NEMCLAW_MODEL=nemoclaw

# Lightweight tier — smaller/faster/cheaper models for search-facing LLM work (queued, max parallelism)
# LIGHTWEIGHT_MODEL=lightweight-search
# LIGHT_QUEUE_MAX_PARALLEL=4

# Search / LLM keys (add as you integrate)
# SEARCH_API_KEY=
# OPENAI_API_KEY=
